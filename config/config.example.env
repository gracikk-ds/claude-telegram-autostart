# claude-telegram-autostart — runtime configuration
# Sourced by start-claude-telegram.sh. All variables are optional;
# defaults in the script will be used if unset.

# Working directory for the claude session.
PROJECT_DIR="$HOME"

# tmux session name. Pick something unique to avoid collisions.
TMUX_SESSION="claude-tg"

# Absolute paths to binaries. Auto-detected by install.sh; set explicitly
# if your tmux/claude live somewhere unusual.
# TMUX_BIN="/opt/homebrew/bin/tmux"
# CLAUDE_BIN="$HOME/.local/bin/claude"

# Channel spec passed to `claude --channels`.
CHANNELS_SPEC="plugin:telegram@claude-plugins-official"

# Seconds before the macOS confirmation dialog auto-dismisses (treated as Skip).
DIALOG_TIMEOUT=30

# Where the start script appends its own log lines.
LOG_FILE="$HOME/Library/Logs/claude-telegram.log"
